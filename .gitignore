# 1. Create the ignore file if it doesn't exist
echo "node_modules/" > .gitignore
echo ".env" >> .gitignore
echo "*.sqlite" >> .gitignore

# 2. Tell Git to "forget" the bad files (node_modules and sqlite files)
git rm -r --cached node_modules --ignore-unmatch
git rm --cached database.sqlite --ignore-unmatch

# 3. Save and Push
git add .
git commit -m "Fix: Switch to Postgres and clean git tracking"
git push origin main